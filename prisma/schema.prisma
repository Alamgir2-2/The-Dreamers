generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donor {
  id           String   @id @default(uuid())
  name         String
  bloodGroup   String
  phone        String
  address      String
  institute    String
  lastDonation DateTime
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bloodGroup])
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  password          String
  photo             String?
  school            String?
  sscBatch          String?
  college           String?
  hscBatch          String?
  university        String?
  department        String?
  bloodGroup        String?
  mobile            String?
  permanentAddress  String?
  currentAddress    String?
  
  // Profession fields
  professionType    String?  // Student, Teacher, Doctor, Engineer, Army Person, Govt Job, Probasi
  institution       String?  // Institution/Company/Hospital/Department
  designation       String?  // Designation/Rank/Post
  specialization    String?  // Subject/Specialization/Field
  
  // Organization fields
  orgPosition       String?
  orgBranch         String?
  orgJoinDate       DateTime?
  
  lastBloodDonation DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
